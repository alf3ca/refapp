<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Import from Centre Circle - Referee Portal</title>
  <link rel="stylesheet" href="/static/style.css">
  <style>
    .import-container {
      max-width: 600px;
      margin: 40px auto;
      padding: 30px;
      background: var(--card-bg);
      border-radius: 12px;
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-lg);
    }

    @media (max-width: 900px) {
      .import-container {
        margin: 20px;
        max-width: calc(100% - 40px);
      }
    }

    .import-header {
      text-align: center;
      margin-bottom: 30px;
    }

    .import-header h1 {
      font-size: 28px;
      margin: 0 0 10px 0;
      color: var(--text-dark);
    }

    .import-header p {
      color: var(--text-light);
      margin: 0;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--text-dark);
      font-size: 14px;
    }

    .form-group input {
      width: 100%;
      padding: 12px;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      font-size: 14px;
      font-family: inherit;
      box-sizing: border-box;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--primary-color);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .info-box {
      background: #f0f9ff;
      border-left: 4px solid var(--primary-color);
      padding: 15px;
      margin-bottom: 25px;
      border-radius: 8px;
      font-size: 14px;
      color: var(--secondary-color);
    }

    .info-box strong {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
    }

    .warning-box {
      background: #fffbeb;
      border-left: 4px solid var(--warning-color);
      padding: 15px;
      margin-bottom: 25px;
      border-radius: 8px;
      font-size: 14px;
      color: #92400e;
    }

    .warning-box strong {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
    }

    .button-group {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin-top: 25px;
    }

    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      text-decoration: none;
      display: inline-block;
      text-align: center;
    }

    .btn-primary {
      background: var(--primary-color);
      color: white;
    }

    .btn-primary:hover {
      background: var(--secondary-color);
    }

    .btn-primary:disabled {
      background: var(--text-light);
      cursor: not-allowed;
      opacity: 0.6;
    }

    .btn-secondary {
      background: var(--border-color);
      color: var(--text-dark);
      text-decoration: none;
    }

    .btn-secondary:hover {
      background: #d1d5db;
    }

    .message {
      padding: 12px 15px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: 14px;
      border-left: 4px solid;
    }

    .message.success {
      background: #ecfdf5;
      border-left-color: var(--success-color);
      color: #065f46;
    }

    .message.error {
      background: #fef2f2;
      border-left-color: var(--error-color);
      color: #991b1b;
    }

    .loading {
      display: none;
      text-align: center;
      margin: 20px 0;
    }

    .spinner {
      border: 3px solid var(--border-color);
      border-top: 3px solid var(--primary-color);
      border-radius: 50%;
      width: 30px;
      height: 30px;
      animation: spin 0.8s linear infinite;
      margin: 0 auto;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .loading-text {
      margin-top: 10px;
      color: var(--text-light);
      font-size: 14px;
    }

    /* Profile Dropdown Styles */
    .profile-menu {
      position: relative;
      display: flex;
      align-items: center;
    }

    .profile-button {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .profile-button:hover {
      transform: scale(1.05);
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
    }

    .dropdown-menu {
      position: absolute;
      top: 50px;
      right: 0;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      box-shadow: var(--shadow-lg);
      min-width: 200px;
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: opacity 0.3s, visibility 0.3s, transform 0.3s;
    }

    .dropdown-menu.active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown-item {
      display: block;
      width: 100%;
      padding: 12px 16px;
      border: none;
      background: none;
      text-align: left;
      cursor: pointer;
      font-size: 14px;
      color: var(--text-dark);
      transition: background-color 0.2s;
      text-decoration: none;
    }

    .dropdown-item:hover {
      background-color: var(--bg-color);
    }

    .dropdown-item:first-child {
      border-radius: 8px 8px 0 0;
    }

    .dropdown-item:last-child {
      border-radius: 0 0 8px 8px;
    }

    .dropdown-divider {
      height: 1px;
      background-color: var(--border-color);
      margin: 4px 0;
    }

    .dropdown-item.danger {
      color: var(--error-color);
    }

    .dropdown-item.danger:hover {
      background-color: #fee2e2;
    }
  </style>
</head>
<body>
  <div class="container">
    <nav class="navbar">
      <a href="/dashboard" class="nav-brand">⚽ Referee Portal</a>
      <div class="nav-menu">
        <div class="profile-menu">
          <button class="profile-button" id="profileBtn" title="Profile">👤</button>
          <div class="dropdown-menu" id="dropdownMenu">
            <a href="/profile" class="dropdown-item">🔧 My Profile</a>
            <a href="/profile" class="dropdown-item">⚙️ Settings</a>
            <div class="dropdown-divider"></div>
            <a href="/logout" class="dropdown-item danger">🚪 Logout</a>
          </div>
        </div>
      </div>
    </nav>

    <%- include('partials/side-menu'); %>

    <div class="dashboard-layout">
      <div class="import-container">
        <div class="import-header">
          <h1>Import from Centre Circle</h1>
          <p>Automatically import your fixtures</p>
        </div>

        <div id="messageContainer"></div>

        <div class="info-box">
          <strong>How it works:</strong>
          Log in with your Centre Circle account credentials. We'll fetch all your assigned fixtures and import them as upcoming matches.
        </div>

        <div class="warning-box">
          <strong>🔒 Security note:</strong>
          Your Centre Circle credentials are used only for this import and are not stored on our servers.
        </div>

        <form id="importForm">
          <div class="form-group">
            <label for="email">Centre Circle Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="your@email.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="password">Centre Circle Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
            />
          </div>

          <div class="loading" id="loading">
            <div class="spinner"></div>
            <div class="loading-text">Importing your fixtures... This may take a minute.</div>
          </div>

          <div class="button-group">
            <button type="submit" class="btn btn-primary" id="submitBtn">Import Fixtures</button>
            <a href="/my-games" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Profile dropdown toggle
    const profileBtn = document.getElementById('profileBtn');
    const dropdownMenu = document.getElementById('dropdownMenu');

    profileBtn.addEventListener('click', () => {
      dropdownMenu.classList.toggle('active');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.profile-menu')) {
        dropdownMenu.classList.remove('active');
      }
    });

    // Form submission
    document.getElementById('importForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const messageContainer = document.getElementById('messageContainer');
      const submitBtn = document.getElementById('submitBtn');
      const loading = document.getElementById('loading');

      if (!email || !password) {
        messageContainer.innerHTML = '<div class="message error">Please fill in all fields</div>';
        return;
      }

      submitBtn.disabled = true;
      loading.style.display = 'block';
      messageContainer.innerHTML = '';

      try {
        const response = await fetch('/api/import-centre-circle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
          credentials: 'same-origin'
        });

        const data = await response.json();

        if (response.ok) {
          messageContainer.innerHTML = `<div class="message success">✅ ${data.message}</div>`;
          setTimeout(() => {
            window.location.href = '/my-games';
          }, 2000);
        } else {
          messageContainer.innerHTML = `<div class="message error">❌ ${data.error || 'Import failed'}</div>`;
        }
      } catch (error) {
        messageContainer.innerHTML = `<div class="message error">❌ Error: ${error.message}</div>`;
      } finally {
        submitBtn.disabled = false;
        loading.style.display = 'none';
      }
    });
  </script>
</body>
</html>
