<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Matches - Referee Portal</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <a href="/dashboard" class="nav-brand">⚽ Referee Portal</a>
            <div class="nav-menu">
                <a href="/dashboard" class="nav-link">Dashboard</a>
                <a href="/profile" class="nav-link">My Profile</a>
                <a href="/my-games" class="nav-link active">My Matches</a>
                <a href="/logout" class="nav-link logout">Logout</a>
            </div>
        </nav>

        <%- include('partials/side-menu') %>

        <div class="profile-container">
            <h1>🗂️ My Matches</h1>

            <div class="profile-card">
                <div class="profile-form">
                    <div class="form-section">
                        <% if (!myGames || myGames.length === 0) { %>
                            <p>No matches added yet.</p>
                            <a href="/games/new" class="btn-primary" style="display: inline-block; margin-top: 16px;">+ Log Your First Match</a>
                        <% } else { %>
                            <div class="games-list">
                                <% myGames.forEach((game) => { %>
                                    <div class="game-row" style="border: 1px solid var(--border-color); padding: 16px; margin-bottom: 12px; border-radius: 8px; cursor: pointer; transition: all 0.3s ease; background: #f9fafb;" onclick="toggleGameDetails(this)">
                                        <div class="game-main"><strong><%= game.homeTeam %> vs <%= game.awayTeam %></strong></div>
                                        <div class="game-meta"><strong>Date:</strong> <%= game.matchDate || '-' %> <%= game.kickoffTime || '' %></div>
                                        <div class="game-meta"><strong>League:</strong> <%= game.league || '-' %></div>
                                        <div class="game-meta"><strong>Venue:</strong> <%= game.venue %></div>
                                        <div class="game-meta"><strong>Status:</strong> <%= game.status || '-' %></div>
                                        <div class="game-details" style="display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-color);">
                                            <div class="game-meta"><strong>Age Group:</strong> <%= game.ageGroup %></div>
                                            <div class="game-meta"><strong>Role:</strong> <%= game.role || '-' %></div>
                                            <div class="game-meta"><strong>Travel:</strong> <%= game.travelTimeMinutes ?? '-' %> min, <%= game.travelDistanceMiles ?? '-' %> miles</div>
                                            <div class="game-meta"><strong>Fee:</strong> £<%= Number(game.matchFee || 0).toFixed(2) %> (<%= game.feePaid ? 'Paid' : 'Unpaid' %>)</div>
                                            <div class="game-meta"><strong>Report:</strong> <%= game.reportSubmitted ? 'Submitted' : 'Due' %></div>
                                            <div class="game-meta"><strong>Notes:</strong> <%= game.personalNotes || '-' %></div>
                                            <div class="game-meta"><strong>Incidents:</strong> <%= game.incidentNotes || '-' %></div>
                                            <div class="game-meta">
                                                <strong>Attachments:</strong>
                                                <% if (game.attachments && game.attachments.length > 0) { %>
                                                    <% game.attachments.forEach((file, index) => { %>
                                                        <a href="<%= file.path %>" target="_blank" rel="noopener noreferrer"><%= file.originalName || `Attachment ${index + 1}` %></a><%= index < game.attachments.length - 1 ? ', ' : '' %>
                                                    <% }) %>
                                                <% } else { %>
                                                    -
                                                <% } %>
                                            </div>
                                            <div class="game-meta"><strong>Created:</strong> <%= new Date(game.createdAt).toLocaleString() %></div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <a href="/games/new" class="btn-primary">+ Log New Match</a>
                <a href="/dashboard" class="btn-secondary">Back to Dashboard</a>
            </div>
        </div>
    </div>

    <script src="/static/side-menu.js"></script>
    <script>
        function toggleGameDetails(element) {
            const details = element.querySelector('.game-details');
            if (details) {
                details.style.display = details.style.display === 'none' ? 'block' : 'none';
            }
        }
    </script>
</body>
</html>
