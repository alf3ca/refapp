<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Game - Referee Portal</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <a href="/dashboard" class="nav-brand">⚽ Referee Portal</a>
            <div class="nav-menu">
                <a href="/dashboard" class="nav-link">Dashboard</a>
                <a href="/referees" class="nav-link">All Referees</a>
                <a href="/profile" class="nav-link">My Profile</a>
                <a href="/games/new" class="nav-link active">Add Game</a>
                <a href="/logout" class="nav-link logout">Logout</a>
            </div>
        </nav>

        <%- include('partials/side-menu') %>

        <div class="profile-container">
            <h1>➕ Add Game</h1>

            <div class="profile-card">
                <form id="addGameForm" class="profile-form">
                    <div class="form-section">
                        <h3>Game Details</h3>

                        <div class="form-group">
                            <label for="homeTeamSelect">Home Team</label>
                            <select id="homeTeamSelect" required>
                                <option value="">Select Home Team</option>
                                <% teams.forEach((team) => { %>
                                    <option value="<%= team %>"><%= team %></option>
                                <% }) %>
                                <option value="__new__">+ Add New Team</option>
                            </select>
                            <input type="text" id="homeTeamNew" placeholder="Enter new home team" style="display:none; margin-top:8px;" />
                        </div>

                        <div class="form-group">
                            <label for="awayTeamSelect">Away Team</label>
                            <select id="awayTeamSelect" required>
                                <option value="">Select Away Team</option>
                                <% teams.forEach((team) => { %>
                                    <option value="<%= team %>"><%= team %></option>
                                <% }) %>
                                <option value="__new__">+ Add New Team</option>
                            </select>
                            <input type="text" id="awayTeamNew" placeholder="Enter new away team" style="display:none; margin-top:8px;" />
                        </div>

                        <div class="form-group">
                            <label for="venueSelect">Venue</label>
                            <select id="venueSelect" required>
                                <option value="">Select Venue</option>
                                <% venues.forEach((venue) => { %>
                                    <option value="<%= venue %>"><%= venue %></option>
                                <% }) %>
                                <option value="__new__">+ Add New Venue</option>
                            </select>
                            <input type="text" id="venueNew" placeholder="Enter new venue" style="display:none; margin-top:8px;" />
                        </div>

                        <div class="form-group">
                            <label for="ageGroup">Age Group</label>
                            <select id="ageGroup" required>
                                <option value="">Select Age Group</option>
                                <% ageGroups.forEach((group) => { %>
                                    <option value="<%= group %>"><%= group %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-primary">Add Game</button>
                        <a href="/dashboard" class="btn-secondary">Back to Dashboard</a>
                    </div>
                </form>

                <div id="gameMessage" style="display:none; margin: 0 30px 20px;"></div>
            </div>
        </div>
    </div>

    <script src="/static/side-menu.js"></script>
    <script>
        const homeTeamSelect = document.getElementById('homeTeamSelect');
        const awayTeamSelect = document.getElementById('awayTeamSelect');
        const venueSelect = document.getElementById('venueSelect');

        const homeTeamNew = document.getElementById('homeTeamNew');
        const awayTeamNew = document.getElementById('awayTeamNew');
        const venueNew = document.getElementById('venueNew');

        const addGameForm = document.getElementById('addGameForm');
        const gameMessage = document.getElementById('gameMessage');

        function toggleNewInput(selectElement, inputElement) {
            if (selectElement.value === '__new__') {
                inputElement.style.display = 'block';
                inputElement.required = true;
                return;
            }

            inputElement.style.display = 'none';
            inputElement.required = false;
            inputElement.value = '';
        }

        function addOptionIfMissing(selectElement, value) {
            const normalized = value.trim().toLowerCase();
            const alreadyExists = Array.from(selectElement.options).some((option) => {
                return option.value.trim().toLowerCase() === normalized;
            });

            if (alreadyExists) {
                return;
            }

            const newOption = document.createElement('option');
            newOption.value = value;
            newOption.textContent = value;

            const addNewOption = selectElement.querySelector('option[value="__new__"]');
            if (addNewOption) {
                selectElement.insertBefore(newOption, addNewOption);
                return;
            }

            selectElement.appendChild(newOption);
        }

        homeTeamSelect.addEventListener('change', () => toggleNewInput(homeTeamSelect, homeTeamNew));
        awayTeamSelect.addEventListener('change', () => toggleNewInput(awayTeamSelect, awayTeamNew));
        venueSelect.addEventListener('change', () => toggleNewInput(venueSelect, venueNew));

        addGameForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const payload = {
                homeTeam: homeTeamSelect.value === '__new__' ? homeTeamNew.value.trim() : homeTeamSelect.value,
                awayTeam: awayTeamSelect.value === '__new__' ? awayTeamNew.value.trim() : awayTeamSelect.value,
                venue: venueSelect.value === '__new__' ? venueNew.value.trim() : venueSelect.value,
                ageGroup: document.getElementById('ageGroup').value
            };

            try {
                const response = await fetch('/api/games', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const body = await response.json();
                    const savedGame = body.game || payload;

                    addOptionIfMissing(homeTeamSelect, savedGame.homeTeam);
                    addOptionIfMissing(awayTeamSelect, savedGame.awayTeam);
                    addOptionIfMissing(venueSelect, savedGame.venue);

                    gameMessage.className = 'success-message';
                    gameMessage.textContent = 'Game added successfully';
                    gameMessage.style.display = 'block';

                    addGameForm.reset();
                    toggleNewInput(homeTeamSelect, homeTeamNew);
                    toggleNewInput(awayTeamSelect, awayTeamNew);
                    toggleNewInput(venueSelect, venueNew);
                    return;
                }

                const body = await response.json();
                gameMessage.className = 'error-message';
                gameMessage.textContent = body.error || 'Could not add game';
                gameMessage.style.display = 'block';
            } catch (error) {
                gameMessage.className = 'error-message';
                gameMessage.textContent = 'An error occurred while adding the game';
                gameMessage.style.display = 'block';
            }
        });
    </script>
</body>
</html>
