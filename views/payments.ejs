<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Payments</title><link rel="stylesheet" href="/static/style.css"></head>
<body><div class="container">
<nav class="navbar"><a href="/dashboard" class="nav-brand">⚽ Referee Portal</a><div class="nav-menu"><a href="/dashboard" class="nav-link">Dashboard</a><a href="/payments" class="nav-link active">Payments</a><a href="/expenses/new" class="nav-link">Add Expense</a><a href="/logout" class="nav-link logout">Logout</a></div></nav>
<%- include('partials/side-menu') %>
<div class="profile-container" style="max-width:1000px;"><h1>💷 Payments</h1>
<div class="profile-card" style="margin-bottom:20px;"><div class="profile-form"><div class="form-section"><h3>Totals by Month</h3>
<% Object.keys(monthTotals).length===0 ? '' : Object.entries(monthTotals).forEach(([month,total])=>{ %><p><strong><%= month %></strong>: £<%= Number(total).toFixed(2) %></p><% }) %>
<% if (!Object.keys(monthTotals).length) { %><p>No payment data yet.</p><% } %>
<h3 style="margin-top:18px;">Totals by Season</h3>
<% Object.keys(seasonTotals).length===0 ? '' : Object.entries(seasonTotals).forEach(([season,total])=>{ %><p><strong><%= season %></strong>: £<%= Number(total).toFixed(2) %></p><% }) %>
<% if (!Object.keys(seasonTotals).length) { %><p>No season totals yet.</p><% } %>
<a href="/payments/export.csv" class="btn-secondary">Export for Tax / Self-Employment (CSV)</a>
</div></div></div>

<div class="profile-card"><div class="profile-form"><div class="form-section"><h3>Entries</h3>
<% if (!allEntries.length) { %><p>No payment entries yet.</p><% } %>
<% allEntries.forEach((entry)=>{ %><p><strong><%= entry.date %></strong> — <%= entry.type %> — £<%= Number(entry.amount).toFixed(2) %> — <%= entry.paid ? 'Paid' : 'Unpaid' %> — <%= entry.notes %></p><% }) %>
<h3 style="margin-top:20px;">Mark Match Fee Paid/Unpaid</h3>
<% if (!matches.length) { %><p>No matches found.</p><% } %>
<% matches.forEach((match)=>{ %>
  <div style="margin-bottom:8px;">
    <strong>#<%= match.id %></strong> <%= match.homeTeam %> vs <%= match.awayTeam %> — currently <%= match.feePaid ? 'Paid' : 'Unpaid' %>
    <button
      class="btn-secondary"
      style="margin-top:6px;"
      data-id="<%= match.id %>"
      data-paid="<%= match.feePaid ? 'false' : 'true' %>"
      onclick="updateMatchPaid(this.dataset.id, this.dataset.paid)">
      <%= match.feePaid ? 'Mark Unpaid' : 'Mark Paid' %>
    </button>
  </div>
<% }) %>
<div id="payMsg" style="display:none; margin-top:10px;"></div>
</div></div></div>
</div></div>
<script src="/static/side-menu.js"></script>
<script>
async function updateMatchPaid(id, feePaid){ const res=await fetch('/api/matches/'+id+'/payment-status',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({feePaid})}); const body=await res.json(); const el=document.getElementById('payMsg'); el.style.display='block'; el.className=res.ok?'success-message':'error-message'; el.textContent=res.ok?'Updated. Reloading...':(body.error||'Error'); if(res.ok) setTimeout(()=>location.reload(),400); }
</script>
</body></html>
