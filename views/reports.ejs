<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Match Reports</title><link rel="stylesheet" href="/static/style.css"></head>
<body><div class="container"><nav class="navbar"><a href="/dashboard" class="nav-brand">⚽ Referee Portal</a><div class="nav-menu"><a href="/dashboard" class="nav-link">Dashboard</a><a href="/reports" class="nav-link active">Reports</a><a href="/reports/new" class="nav-link">New Report</a><a href="/logout" class="nav-link logout">Logout</a></div></nav>
<%- include('partials/side-menu') %>
<div class="profile-container" style="max-width:900px;"><h1>📝 Match Reports</h1>
<div class="profile-card"><div class="profile-form"><div class="form-section"><h3>Saved Reports</h3>
<% if (!myReports.length) { %><p>No reports yet.</p><% } %>
<% myReports.forEach((r)=>{ const m=matchesById.get(r.matchId); %>
<div style="margin-bottom:14px;"><p><strong>#<%= r.id %></strong> — <%= r.reportType %> <%= r.isDraft ? '(Draft)' : '' %></p><p><%= m ? (m.homeTeam + ' vs ' + m.awayTeam) : 'Match #' + r.matchId %></p><p><a href="/reports/<%= r.id %>/text">Export Text</a> | <a href="/reports/<%= r.id %>/pdf">Export PDF</a></p></div>
<% }) %>
</div></div></div>
</div></div><script src="/static/side-menu.js"></script></body></html>
