<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Documents</title><link rel="stylesheet" href="/static/style.css"></head>
<body><div class="container"><nav class="navbar"><a href="/dashboard" class="nav-brand">⚽ Referee Portal</a><div class="nav-menu"><a href="/dashboard" class="nav-link">Dashboard</a><a href="/documents" class="nav-link active">Documents</a><a href="/logout" class="nav-link logout">Logout</a></div></nav>
<%- include('partials/side-menu') %>
<div class="profile-container" style="max-width:900px;"><h1>📁 Documents</h1>
<div class="profile-card" style="margin-bottom:20px;"><form id="documentForm" class="profile-form" enctype="multipart/form-data"><div class="form-section"><h3>Upload Document</h3>
<div class="form-group"><label>Category</label><select id="category" required><option value="">Select</option><% categories.forEach((c)=>{ %><option value="<%= c %>"><%= c %></option><% }) %></select></div>
<div class="form-group"><label>Title</label><input id="title" required></div>
<div class="form-group"><label>File</label><input id="documentFile" type="file" required></div>
</div><div class="form-actions"><button class="btn-primary" type="submit">Upload</button></div></form><div id="docMsg" style="display:none; margin:0 30px 20px;"></div></div>
<div class="profile-card"><div class="profile-form"><div class="form-section"><h3>Stored Documents</h3>
<% if (!documents.length) { %><p>No documents uploaded yet.</p><% } %>
<% documents.forEach((d)=>{ %><p><strong><%= d.category %></strong> — <%= d.title %> — <a href="<%= d.path %>" target="_blank" rel="noopener noreferrer">Open</a></p><% }) %>
</div></div></div>
</div></div>
<script src="/static/side-menu.js"></script>
<script>
documentForm.addEventListener('submit', async (e)=>{e.preventDefault(); const data=new FormData(); data.append('category',category.value); data.append('title',title.value.trim()); if(documentFile.files[0]) data.append('documentFile',documentFile.files[0]); const res=await fetch('/api/documents',{method:'POST',body:data}); const b=await res.json(); docMsg.style.display='block'; docMsg.className=res.ok?'success-message':'error-message'; docMsg.textContent=res.ok?'Uploaded. Reloading...':(b.error||'Error'); if(res.ok) setTimeout(()=>location.reload(),400);});
</script></body></html>
