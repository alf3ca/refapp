<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Referee Portal</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="login-container">
        <div class="login-box">
            <h1>⚽ Referee Portal</h1>
            <p class="subtitle">Choose how you want to continue</p>

            <div class="auth-footer" style="margin-top: 0;">
                <a href="/login" class="btn-login" style="display: block; text-align: center; text-decoration: none;">Login</a>
                <a href="/register" class="btn-secondary auth-btn">Create Account</a>
            </div>
        </div>
    </div>
</body>

<script>
const express = require("express");
const path = require("path");
const app = express();

app.set("views", path.join(__dirname, "views"));
app.set("view engine", "ejs");
</script>
</html>
