<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Referee Portal</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="login-container">
        <div class="login-box">
            <h1>⚽ Referee Portal</h1>
            <p class="subtitle">Your Professional Match Management Hub</p>

            <div style="margin-top: 30px; display: flex; flex-direction: column; gap: 12px;">
                <a href="/login" class="btn-login" style="display: block; text-align: center; text-decoration: none; padding: 14px; border: none; cursor: pointer;">
                    Login to Your Account
                </a>
                <a href="/register" class="btn-login" style="display: block; text-align: center; text-decoration: none; padding: 14px; border: none; cursor: pointer; background: var(--success-color);">
                    Create New Account
                </a>
            </div>
        </div>
    </div>
</body>
</html>
