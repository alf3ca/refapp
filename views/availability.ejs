<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Availability Planner</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
<div class="container">
  <nav class="navbar">
    <a href="/dashboard" class="nav-brand">⚽ Referee Portal</a>
    <div class="nav-menu">
      <a href="/dashboard" class="nav-link">Dashboard</a>
      <a href="/availability" class="nav-link active">Availability</a>
      <a href="/logout" class="nav-link logout">Logout</a>
    </div>
  </nav>

  <%- include('partials/side-menu') %>

  <div class="profile-container" style="max-width:900px;">
    <h1>📆 Availability Planner</h1>

    <div class="profile-card" style="margin-bottom:20px;">
      <form id="availabilityDateForm" class="profile-form">
        <div class="form-section">
          <h3>Mark Date</h3>
          <div class="form-group"><label for="date">Date</label><input id="date" type="date" required></div>
          <div class="form-group">
            <label for="status">Status</label>
            <select id="status" required>
              <option value="">Select</option>
              <option value="available">Available</option>
              <option value="unavailable">Unavailable</option>
            </select>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn-primary" type="submit">Save Date</button>
          <a class="btn-secondary" href="/availability.ics">Sync with Calendar (.ics)</a>
        </div>
      </form>
      <div id="dateMsg" style="display:none; margin: 0 30px 20px;"></div>
    </div>

    <div class="profile-card" style="margin-bottom:20px;">
      <form id="availabilitySettingsForm" class="profile-form">
        <div class="form-section">
          <h3>Preferences</h3>
          <div class="form-group"><label for="preferredKickoffStart">Preferred Kickoff Start</label><input id="preferredKickoffStart" type="time" value="<%= settings.preferredKickoffStart %>"></div>
          <div class="form-group"><label for="preferredKickoffEnd">Preferred Kickoff End</label><input id="preferredKickoffEnd" type="time" value="<%= settings.preferredKickoffEnd %>"></div>
          <div class="form-group"><label for="maxTravelDistanceMiles">Maximum Travel Distance (miles)</label><input id="maxTravelDistanceMiles" type="number" min="0" step="0.1" value="<%= settings.maxTravelDistanceMiles %>"></div>
          <div class="form-group"><label for="blockedWeekendDate">Add Blocked Weekend Date</label><input id="blockedWeekendDate" type="date"></div>
        </div>
        <div class="form-actions"><button class="btn-primary" type="submit">Save Preferences</button></div>
      </form>
      <div id="settingsMsg" style="display:none; margin: 0 30px 20px;"></div>
    </div>

    <div class="profile-card">
      <div class="profile-form">
        <div class="form-section">
          <h3>Saved Dates</h3>
          <% if (!dates.length) { %><p>No availability dates saved.</p><% } %>
          <% dates.forEach((item) => { %>
            <p><strong><%= item.date %></strong> — <%= item.status %></p>
          <% }) %>
          <h3>Blocked Weekends</h3>
          <% if (!blockedWeekends.length) { %><p>No blocked weekends saved.</p><% } %>
          <% blockedWeekends.forEach((item) => { %>
            <p><strong><%= item.date %></strong></p>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/static/side-menu.js"></script>
<script>
const dateForm=document.getElementById('availabilityDateForm');
const settingsForm=document.getElementById('availabilitySettingsForm');
const dateMsg=document.getElementById('dateMsg');
const settingsMsg=document.getElementById('settingsMsg');

dateForm.addEventListener('submit', async (e)=>{
 e.preventDefault();
 const payload={date:document.getElementById('date').value,status:document.getElementById('status').value};
 const res=await fetch('/api/availability/date',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
 const body=await res.json();
 dateMsg.style.display='block';
 dateMsg.className=res.ok?'success-message':'error-message';
 dateMsg.textContent=res.ok?'Saved. Reloading...':(body.error||'Error');
 if(res.ok) setTimeout(()=>location.reload(),400);
});

settingsForm.addEventListener('submit', async (e)=>{
 e.preventDefault();
 const payload={
  preferredKickoffStart:document.getElementById('preferredKickoffStart').value,
  preferredKickoffEnd:document.getElementById('preferredKickoffEnd').value,
  maxTravelDistanceMiles:document.getElementById('maxTravelDistanceMiles').value,
  blockedWeekendDate:document.getElementById('blockedWeekendDate').value
 };
 const res=await fetch('/api/availability/settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
 const body=await res.json();
 settingsMsg.style.display='block';
 settingsMsg.className=res.ok?'success-message':'error-message';
 settingsMsg.textContent=res.ok?'Saved. Reloading...':(body.error||'Error');
 if(res.ok) setTimeout(()=>location.reload(),400);
});
</script>
</body>
</html>
