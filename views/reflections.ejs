<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Notes & Reflection</title><link rel="stylesheet" href="/static/style.css"></head>
<body><div class="container"><nav class="navbar"><a href="/dashboard" class="nav-brand">⚽ Referee Portal</a><div class="nav-menu"><a href="/dashboard" class="nav-link">Dashboard</a><a href="/reflections" class="nav-link active">Reflections</a><a href="/logout" class="nav-link logout">Logout</a></div></nav>
<%- include('partials/side-menu') %>
<div class="profile-container" style="max-width:900px;"><h1>🧠 Notes and Reflection</h1>
<div class="profile-card" style="margin-bottom:20px;"><form id="reflectionForm" class="profile-form"><div class="form-section"><h3>New Reflection</h3>
<div class="form-group"><label>What went well</label><textarea id="wentWell" rows="3"></textarea></div>
<div class="form-group"><label>What went badly</label><textarea id="wentBadly" rows="3"></textarea></div>
<div class="form-group"><label>Difficult incidents</label><textarea id="difficultIncidents" rows="3"></textarea></div>
<div class="form-group"><label>Positioning issues</label><textarea id="positioningIssues" rows="3"></textarea></div>
<div class="form-group"><label>Player management lessons</label><textarea id="playerManagementLessons" rows="3"></textarea></div>
<div class="form-group"><label>Improvements for next time</label><textarea id="improvementsNextTime" rows="3"></textarea></div>
</div><div class="form-actions"><button class="btn-primary" type="submit">Save Reflection</button></div></form><div id="reflectionMsg" style="display:none; margin:0 30px 20px;"></div></div>
<div class="profile-card"><div class="profile-form"><div class="form-section"><h3>Saved Reflections</h3>
<% if (!entries.length) { %><p>No reflections saved yet.</p><% } %>
<% entries.forEach((entry)=>{ %>
<div style="margin-bottom:14px;"><p><strong><%= new Date(entry.createdAt).toLocaleString() %></strong></p><p><strong>Well:</strong> <%= entry.wentWell || '-' %></p><p><strong>Badly:</strong> <%= entry.wentBadly || '-' %></p><p><strong>Difficult:</strong> <%= entry.difficultIncidents || '-' %></p><p><strong>Positioning:</strong> <%= entry.positioningIssues || '-' %></p><p><strong>Player Mgmt:</strong> <%= entry.playerManagementLessons || '-' %></p><p><strong>Improve:</strong> <%= entry.improvementsNextTime || '-' %></p></div>
<% }) %>
</div></div></div>
</div></div>
<script src="/static/side-menu.js"></script>
<script>
reflectionForm.addEventListener('submit', async (e)=>{e.preventDefault(); const payload={wentWell:wentWell.value.trim(),wentBadly:wentBadly.value.trim(),difficultIncidents:difficultIncidents.value.trim(),positioningIssues:positioningIssues.value.trim(),playerManagementLessons:playerManagementLessons.value.trim(),improvementsNextTime:improvementsNextTime.value.trim()}; const res=await fetch('/api/reflections',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}); const b=await res.json(); reflectionMsg.style.display='block'; reflectionMsg.className=res.ok?'success-message':'error-message'; reflectionMsg.textContent=res.ok?'Saved. Reloading...':(b.error||'Error'); if(res.ok) setTimeout(()=>location.reload(),400);});
</script></body></html>
