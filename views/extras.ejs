<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Useful Extras</title><link rel="stylesheet" href="/static/style.css"></head>
<body><div class="container"><nav class="navbar"><a href="/dashboard" class="nav-brand">⚽ Referee Portal</a><div class="nav-menu"><a href="/dashboard" class="nav-link">Dashboard</a><a href="/extras" class="nav-link active">Extras</a><a href="/logout" class="nav-link logout">Logout</a></div></nav>
<%- include('partials/side-menu') %>
<div class="profile-container" style="max-width:900px;"><h1>🧰 Useful Extras</h1>
<div class="profile-card" style="margin-bottom:20px;"><div class="profile-form"><div class="form-section"><h3>Quick Links & Reference</h3>
<p><a href="https://www.bbc.co.uk/weather" target="_blank" rel="noopener noreferrer">Weather</a></p>
<p><a href="https://maps.google.com" target="_blank" rel="noopener noreferrer">Sat-nav</a></p>
<p><strong>Match Day Notebook Template:</strong> Heads/Tails, kick-off, captains, key incidents, cautions, dismissals.</p>
</div></div></div>

<div class="profile-card"><form id="checklistForm" class="profile-form"><div class="form-section"><h3>Checklists & Kit Inventory</h3>
<div class="form-group"><label>What do you want to add?</label><select id="itemType"><option value="preMatchChecklist">Pre-match Checklist</option><option value="packingChecklist">Packing Checklist</option><option value="kit">Kit Inventory</option></select></div>
<div class="form-group"><label>Item</label><input id="checkItem" placeholder="e.g., Coin, Whistle, Notebook"></div>
<div id="kitFields" style="display:none;"><div class="form-group"><label>Quantity</label><input id="kitQty" type="number" min="1" value="1"></div>
<div class="form-group"><label>Notes</label><input id="kitNotes" placeholder="e.g., red & yellow"></div></div>
<div class="form-section" style="margin-top:20px;"><h4>Pre-match Checklist</h4>
<% if (preMatchChecklist.length) { %><% preMatchChecklist.forEach((i)=>{ %><p>- <%= i.item %></p><% }) %><% } else { %><p>No items yet.</p><% } %>
</div>
<div class="form-section" style="margin-top:16px;"><h4>Packing Checklist</h4>
<% if (packingChecklist.length) { %><% packingChecklist.forEach((i)=>{ %><p>- <%= i.item %></p><% }) %><% } else { %><p>No items yet.</p><% } %>
</div>
<div class="form-section" style="margin-top:16px;"><h4>Kit Inventory</h4>
<% if (!kitInventory.length) { %><p>No kit items yet.</p><% } %>
<% kitInventory.forEach((k)=>{ %><p><strong><%= k.item %></strong> x <%= k.quantity %> <%= k.notes ? ('- ' + k.notes) : '' %></p><% }) %>
</div>
<div class="form-actions" style="margin-top:20px;"><button class="btn-primary" type="submit">Add Item</button></div></form><div id="checkMsg" style="display:none; margin:0 30px 20px;"></div></div>
</div></div>
<script src="/static/side-menu.js"></script>
<script>
const itemType = document.getElementById('itemType');
const kitFields = document.getElementById('kitFields');

itemType.addEventListener('change', () => {
  kitFields.style.display = itemType.value === 'kit' ? 'block' : 'none';
});

checklistForm.addEventListener('submit', async (e)=>{
  e.preventDefault();
  const type = itemType.value;
  
  if (type === 'kit') {
    const payload = {
      item: checkItem.value.trim(),
      quantity: kitQty.value,
      notes: kitNotes.value.trim()
    };
    const res = await fetch('/api/extras/kit', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload)
    });
    const b = await res.json();
    checkMsg.style.display = 'block';
    checkMsg.className = res.ok ? 'success-message' : 'error-message';
    checkMsg.textContent = res.ok ? 'Saved. Reloading...' : (b.error || 'Error');
    if (res.ok) setTimeout(() => location.reload(), 400);
  } else {
    const payload = {
      listType: type,
      item: checkItem.value.trim()
    };
    const res = await fetch('/api/extras/checklist', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload)
    });
    const b = await res.json();
    checkMsg.style.display = 'block';
    checkMsg.className = res.ok ? 'success-message' : 'error-message';
    checkMsg.textContent = res.ok ? 'Saved. Reloading...' : (b.error || 'Error');
    if (res.ok) setTimeout(() => location.reload(), 400);
  }
});
</script></body></html>
