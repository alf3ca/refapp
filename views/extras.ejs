<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Useful Extras</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <a href="/dashboard" class="nav-brand">⚽ Referee Portal</a>
            <div class="nav-menu">
                <a href="/dashboard" class="nav-link">Dashboard</a>
                <a href="/extras" class="nav-link active">Extras</a>
                <a href="/logout" class="nav-link logout">Logout</a>
            </div>
        </nav>

        <%- include('partials/side-menu') %>

        <div class="profile-container">
            <h1>🧰 Useful Extras</h1>

            <div class="profile-card" style="margin-bottom: 20px;">
                <div class="profile-form">
                    <div class="form-section">
                        <h3>Quick Links & Reference</h3>
                        <p>
                            <a href="https://www.bbc.co.uk/weather" target="_blank" rel="noopener noreferrer">
                                🌤️ Weather
                            </a>
                        </p>
                        <p>
                            <a href="https://maps.google.com" target="_blank" rel="noopener noreferrer">
                                🗺️ Sat-nav
                            </a>
                        </p>
                        <p>
                            <strong>📝 Match Day Notebook Template:</strong>
                            <br>Heads/Tails, kick-off, captains, key incidents, cautions, dismissals.
                        </p>
                    </div>
                </div>
            </div>

            <div class="profile-card">
                <form id="checklistForm" class="profile-form">
                    <div class="form-section">
                        <h3>Checklists & Kit Inventory</h3>

                        <div class="form-group">
                            <label for="itemType">What do you want to add?</label>
                            <select id="itemType">
                                <option value="preMatchChecklist">Pre-match Checklist</option>
                                <option value="packingChecklist">Packing Checklist</option>
                                <option value="kit">Kit Inventory</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="checkItem">Item</label>
                            <input 
                                id="checkItem" 
                                type="text"
                                placeholder="e.g., Coin, Whistle, Notebook"
                                required
                            >
                        </div>

                        <div id="kitFields" style="display: none;">
                            <div class="form-group">
                                <label for="kitQty">Quantity</label>
                                <input id="kitQty" type="number" min="1" value="1">
                            </div>
                            <div class="form-group">
                                <label for="kitNotes">Notes</label>
                                <input 
                                    id="kitNotes" 
                                    type="text"
                                    placeholder="e.g., red & yellow"
                                >
                            </div>
                        </div>

                        <div class="form-actions">
                            <button class="btn-primary" type="submit">Add Item</button>
                        </div>

                        <div id="checkMsg" style="display: none; margin-top: 16px;"></div>
                    </div>
                </form>

                <div class="form-section" style="margin-top: 24px; border-top: 1px solid var(--border-color); padding-top: 24px;">
                    <h4>Pre-match Checklist</h4>
                    <% if (preMatchChecklist && preMatchChecklist.length) { %>
                        <ul style="margin-left: 20px; margin-top: 12px;">
                            <% preMatchChecklist.forEach((item) => { %>
                                <li style="margin-bottom: 8px;"><%= item.item %></li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p style="color: var(--text-light);">No items yet.</p>
                    <% } %>
                </div>

                <div class="form-section" style="margin-top: 24px;">
                    <h4>Packing Checklist</h4>
                    <% if (packingChecklist && packingChecklist.length) { %>
                        <ul style="margin-left: 20px; margin-top: 12px;">
                            <% packingChecklist.forEach((item) => { %>
                                <li style="margin-bottom: 8px;"><%= item.item %></li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p style="color: var(--text-light);">No items yet.</p>
                    <% } %>
                </div>

                <div class="form-section" style="margin-top: 24px;">
                    <h4>Kit Inventory</h4>
                    <% if (!kitInventory || !kitInventory.length) { %>
                        <p style="color: var(--text-light);">No kit items yet.</p>
                    <% } else { %>
                        <ul style="margin-left: 20px; margin-top: 12px;">
                            <% kitInventory.forEach((kit) => { %>
                                <li style="margin-bottom: 8px;">
                                    <strong><%= kit.item %></strong> × <%= kit.quantity %>
                                    <% if (kit.notes) { %>
                                        <br><span style="font-size: 13px; color: var(--text-light);">(<%= kit.notes %>)</span>
                                    <% } %>
                                </li>
                            <% }) %>
                        </ul>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script src="/static/side-menu.js"></script>
    <script>
        const itemType = document.getElementById('itemType');
        const kitFields = document.getElementById('kitFields');
        const checklistForm = document.getElementById('checklistForm');
        const checkItem = document.getElementById('checkItem');
        const kitQty = document.getElementById('kitQty');
        const kitNotes = document.getElementById('kitNotes');
        const checkMsg = document.getElementById('checkMsg');

        // Show/hide kit fields based on selection
        itemType.addEventListener('change', () => {
            kitFields.style.display = itemType.value === 'kit' ? 'block' : 'none';
        });

        // Form submission
        checklistForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const type = itemType.value;
            
            if (type === 'kit') {
                const payload = {
                    item: checkItem.value.trim(),
                    quantity: parseInt(kitQty.value),
                    notes: kitNotes.value.trim()
                };
                const res = await fetch('/api/extras/kit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const body = await res.json();
                checkMsg.style.display = 'block';
                checkMsg.className = res.ok ? 'success-message' : 'error-message';
                checkMsg.textContent = res.ok ? '✓ Saved. Reloading...' : (body.error || 'Error');
                if (res.ok) setTimeout(() => location.reload(), 600);
            } else {
                const payload = {
                    listType: type,
                    item: checkItem.value.trim()
                };
                const res = await fetch('/api/extras/checklist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const body = await res.json();
                checkMsg.style.display = 'block';
                checkMsg.className = res.ok ? 'success-message' : 'error-message';
                checkMsg.textContent = res.ok ? '✓ Saved. Reloading...' : (body.error || 'Error');
                if (res.ok) setTimeout(() => location.reload(), 600);
            }
            
            // Clear form
            checkItem.value = '';
            kitQty.value = '1';
            kitNotes.value = '';
        });
    </script>
</body>
</html>
