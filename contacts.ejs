<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Contacts</title><link rel="stylesheet" href="/static/style.css"></head>
<body><div class="container"><nav class="navbar"><div class="nav-brand">⚽ Referee Portal</div><div class="nav-menu"><a href="/dashboard" class="nav-link">Dashboard</a><a href="/contacts" class="nav-link active">Contacts</a><a href="/logout" class="nav-link logout">Logout</a></div></nav>
<%- include('partials/side-menu') %>
<div class="profile-container" style="max-width:900px;"><h1>☎️ Contacts</h1>
<div class="profile-card" style="margin-bottom:20px;"><form id="contactForm" class="profile-form"><div class="form-section"><h3>Add Contact</h3>
<div class="form-group"><label>Category</label><select id="category" required><option value="">Select</option><option>League Secretary</option><option>Appointments Officer</option><option>Club Contact</option><option>Fellow Referee</option><option>Emergency Venue Contact</option></select></div>
<div class="form-group"><label>Name</label><input id="name" required></div>
<div class="form-group"><label>Phone</label><input id="phone"></div>
<div class="form-group"><label>Email</label><input id="email" type="email"></div>
<div class="form-group"><label>Notes</label><textarea id="notes" rows="3"></textarea></div>
</div><div class="form-actions"><button class="btn-primary" type="submit">Save Contact</button></div></form><div id="contactMsg" style="display:none; margin:0 30px 20px;"></div></div>
<div class="profile-card"><div class="profile-form"><div class="form-section"><h3>Saved Contacts</h3>
<% if (!entries.length) { %><p>No contacts saved yet.</p><% } %>
<% entries.forEach((c)=>{ %><p><strong><%= c.category %></strong> — <%= c.name %> <%= c.phone ? ('| ' + c.phone) : '' %> <%= c.email ? ('| ' + c.email) : '' %> <%= c.notes ? ('| ' + c.notes) : '' %></p><% }) %>
</div></div></div>
</div></div>
<script src="/static/side-menu.js"></script>
<script>
contactForm.addEventListener('submit', async (e)=>{e.preventDefault(); const payload={category:category.value,name:name.value.trim(),phone:phone.value.trim(),email:email.value.trim(),notes:notes.value.trim()}; const res=await fetch('/api/contacts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}); const b=await res.json(); contactMsg.style.display='block'; contactMsg.className=res.ok?'success-message':'error-message'; contactMsg.textContent=res.ok?'Saved. Reloading...':(b.error||'Error'); if(res.ok) setTimeout(()=>location.reload(),400);});
</script></body></html>
